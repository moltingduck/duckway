# Agent environment variables
# Copy to .env and fill in values

# Tailscale auth key
TS_AUTHKEY=tskey-auth-xxxxx

# Tailscale hostname for this agent node
TS_HOSTNAME=my-agent

# Duckway gateway URL (Tailscale HTTPS)
DUCKWAY_GATEWAY=https://duckway-gw.your-tailnet.ts.net

# Client token (from Duckway admin panel → Clients → Register)
DUCKWAY_CLIENT_TOKEN=abc123...

# Client name (must be unique per agent)
DUCKWAY_CLIENT_NAME=my-agent

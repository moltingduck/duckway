# Claude Code Agent environment
# Copy to .env: cp .env.claude.example .env
#
# NO API keys here. Duckway proxy handles all key injection.

# Tailscale
TS_AUTHKEY=tskey-auth-xxxxx
TS_HOSTNAME=claude-agent

# Duckway gateway (Tailscale HTTPS URL)
DUCKWAY_GATEWAY=https://duckway-gw.your-tailnet.ts.net

# Client auth token (from admin panel → Clients → Register)
# This is NOT an API key — it only identifies the client to the gateway
DUCKWAY_CLIENT_TOKEN=abc123...
DUCKWAY_CLIENT_NAME=claude-agent

# Your project workspace to mount into the container
WORKSPACE_DIR=/path/to/your/project

# Duckway environment variables
# Copy to .env and fill in values. Never commit .env to git.

# Tailscale auth key (from https://login.tailscale.com/admin/settings/keys)
TS_AUTHKEY=tskey-auth-xxxxx

# Tailscale hostname for this node
TS_HOSTNAME=duckway

# Discord bot (optional, for notifications)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Production mode: split (recommended) or combined
DUCKWAY_PROD_MODE=split
